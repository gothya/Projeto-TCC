rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Participantes ────────────────────────────────────────────────────────
    // Cada participante lê e escreve apenas o próprio documento (uid == docId).
    // Admin (Custom Claim `admin: true`) pode ler qualquer documento.
    match /participantes/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null &&
                               (request.auth.uid == userId || request.auth.token.admin == true);
      allow read: if request.auth != null &&
                    (request.auth.uid == userId || request.auth.token.admin == true);
    }

    // ── Avaliações de Reação ─────────────────────────────────────────────────
    // Participante cria o próprio documento uma única vez.
    // Admin lê qualquer avaliação.
    match /reactionEvaluations/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if false; // imutável após envio
      allow read: if request.auth != null &&
                    (request.auth.uid == userId || request.auth.token.admin == true);
    }

    // ── Mensagens Públicas ───────────────────────────────────────────────────
    // Leitura pública — exibidas na landing page sem autenticação.
    // Escrita apenas pelo próprio participante (uid == docId), uma única vez.
    match /publicMessages/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if false; // imutável
    }

    // ── Leaderboard ──────────────────────────────────────────────────────
    // Contém apenas { nickname, nicknameLower, points } — sem dados sensíveis.
    // Leitura: qualquer participante autenticado (ranking global).
    // Escrita: apenas o próprio participante escreve o seu documento.
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
                      (request.auth.uid == userId || request.auth.token.admin == true);
    }
  }
}
